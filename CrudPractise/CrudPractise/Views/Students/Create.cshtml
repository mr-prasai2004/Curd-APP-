<!-- CREATE VIEW -->
@model CrudPractise.Models.Student
@{
    ViewData["Title"] = "Create Student";
}

<div class="container">
    <h1>Create New Student</h1>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <h4>Student Information</h4>
                <hr />

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors text-danger"></div>

                    <div class="form-group">
                        <label asp-for="StudentId" class="control-label">Student ID</label>
                        <input asp-for="StudentId" class="form-control" placeholder="Enter student ID" />
                        <span asp-validation-for="StudentId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="StudentName" class="control-label">Student Name</label>
                        <input asp-for="StudentName" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="StudentName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="StdAddress" class="control-label">Address</label>
                        <input asp-for="StdAddress" class="form-control" placeholder="Enter address" />
                        <span asp-validation-for="StdAddress" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CourseId" class="control-label">Course</label>
                        <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId">
                            <option value="">-- Select Course --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>

                    <div class="actions">
                        <input type="submit" value="Create Student" class="btn btn-primary" />
                        <a asp-action="Index" class="btn" style="background: #95a5a6; color: white;">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>